@app.post("/predict", response_model=PredictResponse)
async def predict(file: UploadFile = File(...)) -> PredictResponse:
    """Main prediction endpoint - analyzes ZIP uploads for malicious behavior."""
    raw_bytes = await file.read()
    filename  = file.filename or "upload"

    if len(raw_bytes) > MAX_ZIP_BYTES:
        raise HTTPException(413, "Upload too large.")

    log.info("=" * 60)
    log.info("SCAN  %s  (%d bytes)", filename, len(raw_bytes))
    log.info("=" * 60)

    # Use zip_scanner for in-memory extraction
    members = extract_files_from_upload(raw_bytes, filename)
    
    # Analyze each file using modular components
    # NOTE: member_filename is passed to extract_features for research path detection
    file_results = [analyse_file(mfn, content) for mfn, content in members]
    
    # Generate archive summary
    archive_verdict, archive_score, behavioral_summary = summarise_archive(file_results)

    log.info("ARCHIVE VERDICT: %s  score=%.1f", archive_verdict, archive_score)

    return PredictResponse(
        archive_verdict    = archive_verdict,
        archive_risk_score = archive_score,
        behavioral_summary = behavioral_summary,
        file_results       = file_results,
    )


