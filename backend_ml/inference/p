class FileResult(BaseModel):
    filename:           str
    behavioral_intent:  str
    final_verdict:      str
    risk_score:         float
    extracted_features: dict
    action_chains:      list[str]
    findings:           list[str]


class PredictResponse(BaseModel):
    archive_verdict:    str
    archive_risk_score: float
    behavioral_summary: str
    file_results:       list[FileResult]


